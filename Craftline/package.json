        "test:watch": "vitest",
        "shopify": "shopify",
        "prisma": "prisma"
    },
    "type": "module",
    "engines": {
        "node": ">=24.13.1"
    },
    "dependencies": {
        "@prisma/client": "^7.5.0",
        "@remix-run/node": "^2.9.1",
        "@remix-run/react": "^2.9.1",
        "@remix-run/serve": "^2.9.1",
        "@shopify/app-bridge-react": "^4.2.10",
        "@shopify/polaris": "^13.9.5",
        "@shopify/shopify-app-remix": "^4.2.0",
        "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
        "isbot": "^5.1.0",
        "nodemailer": "^6.9.13",
        "prisma": "^7.5.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@remix-run/dev": "^2.9.1",
        "@vitest/coverage-v8": "^1.4.0",
