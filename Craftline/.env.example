# Shopify app credentials — from your Shopify Partner dashboard
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,write_orders,read_customers,read_metafields,write_metafields

# The public URL of your deployed app (or tunnel URL for local dev)
SHOPIFY_APP_URL=https://makerqueue.uplifttechnologies.pro

# Database — SQLite for local dev; replace with PostgreSQL URL for production
DATABASE_URL="file:./dev.db"

# Optional: for local dev with a custom shop domain
# SHOP_CUSTOM_DOMAIN=
