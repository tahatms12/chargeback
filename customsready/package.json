{
  "name": "customsready-lite",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm start",
    "setup": "prisma generate && prisma migrate deploy",
    "typecheck": "tsc",
    "workers": "tsx --watch app/jobs/catalogAudit.worker.ts & tsx --watch app/jobs/productReaudit.worker.ts",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "deploy": "shopify app deploy"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "^2.13.1",
    "@remix-run/serve": "^2.13.1",
    "@shopify/polaris": "^13.0.0",
    "@shopify/shopify-app-remix": "^3.3.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.0",
    "bullmq": "^5.7.1",
    "ioredis": "^5.3.2",
    "pino": "^9.4.0",
    "puppeteer": "^22.15.0",
    "vite-tsconfig-paths": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.13.1",
    "@shopify/app": "^3.68.0",
    "@shopify/cli": "^3.68.0",
    "@types/node": "^22.0.0",
    "eslint": "^8.57.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
