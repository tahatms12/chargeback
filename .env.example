# App environment variables for each Shopify app
# Copy the relevant block to each app's .env file and fill in real values.
# DO NOT commit .env files with real secrets to git.

# ─── Craftline (Maker Queue) ────────────────────────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=https://craftline.uplifttechnologies.pro
# SCOPES=read_orders,write_orders,read_customers,read_metafields,write_metafields
# DATABASE_URL=

# ─── FixitCSV ────────────────────────────────────────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=https://fixitcsv.uplifttechnologies.pro
# SCOPES=read_products
# DATABASE_URL=

# ─── Stagewise (Production Queue Communicator) ───────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=https://stagewise.uplifttechnologies.pro
# SCOPES=read_orders,write_orders,read_customers
# DATABASE_URL=

# ─── CustomsReady Lite ────────────────────────────────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=https://customsready.uplifttechnologies.pro
# SCOPES=read_products,read_orders
# DATABASE_URL=
# REDIS_URL=  # NOTE: Redis/BullMQ not functional in Netlify serverless — requires dedicated server

# ─── PORef ────────────────────────────────────────────────────────────────────
