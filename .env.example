# Global runtime defaults for local Docker stack
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:8080/customsready
FIXITCSV_APP_URL=http://localhost:8080/fixitcsv
SCOPES=read_products,read_orders

# Service ports
GATEWAY_PORT=8080
CUSTOMSREADY_PORT=3100
FIXITCSV_PORT=3200

# Data services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=customsready_lite
POSTGRES_PORT=5432
REDIS_PORT=6379

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/customsready_lite
REDIS_URL=redis://redis:6379
FIXITCSV_DATABASE_URL=file:./prisma/dev.db
