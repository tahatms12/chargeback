# Authoritative host/port + URL map
# Public/base URLs should always be set to real domains in production.
PUBLIC_BASE_URL=https://chargeguard.uplifttechnologies.pro
FRONTEND_PUBLIC_BASE_URL=https://chargeguard.uplifttechnologies.pro

API_HOST=api
API_PORT=8000
WEB_HOST=web
WEB_PORT=3000
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Core service credentials/config
POSTGRES_USER=chargeguard
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=chargeguard
S3_ACCESS_KEY_ID=change-me-minio-access-key
S3_SECRET_ACCESS_KEY=change-me-minio-secret-key
S3_BUCKET=chargeguard-evidence

# Derived connection strings and service URLs
APP_URL=${PUBLIC_BASE_URL}
SHOPIFY_APP_URL=${FRONTEND_PUBLIC_BASE_URL}
ALLOWED_ORIGINS=${FRONTEND_PUBLIC_BASE_URL},https://admin.shopify.com
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
S3_ENDPOINT_URL=http://${MINIO_HOST}:${MINIO_PORT}
NEXT_PUBLIC_API_URL=http://${API_HOST}:${API_PORT}
