// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Required by @shopify/shopify-app-session-storage-prisma
model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
  firstName   String?
  lastName    String?
  email       String?
  accountOwner Boolean  @default(false)
  locale      String?
  collaborator Boolean? @default(false)
  emailVerified Boolean? @default(false)

  @@index([shop])
}

model Installation {
  id                  String    @id @default(cuid())
  shopDomain          String    @unique
  offlineAccessToken  String    // encrypted at rest via env-keyed AES-256-GCM
  billingStatus       String @default("PENDING")
  appSubscriptionId   String?
  planName            String    @default("basic")
  installedAt         DateTime  @default(now())
  uninstalledAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shopDomain])
}

model Configuration {
  id                           String   @id @default(cuid())
  shopDomain                   String   @unique
  fieldLabel                   String   @default("PO / Reference Number")
  enforcementMode              String @default("OPTIONAL")
  requiredTags                 String @default("[]") // Fallback for postgres text[]
  posEnabled                   Boolean  @default(true)
  orderPrinterSnippetVersion   Int      @default(1)
  notificationSnippetVersion   Int      @default(1)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([shopDomain])
}

model ReferenceIndex {
  id                 String        @id @default(cuid())
  shopDomain         String
  orderId            String        // numeric Shopify order ID (string for safety)
  orderGid           String        // gid://shopify/Order/...
  orderName          String        // "#1001"
  referenceValue     String
  sourceChannel      String @default("ONLINE")
  customerTagMatch   Boolean       @default(false)
  missingReference   Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([shopDomain, orderId])
  @@index([shopDomain])
  @@index([shopDomain, referenceValue])          // fast search
  @@index([shopDomain, missingReference])         // dashboard query
  @@index([shopDomain, createdAt(sort: Desc)])    // recency sort
  @@index([referenceValue])                       // cross-shop search prevention (unused but safe)
}

model AuditLog {
  id         String     @id @default(cuid())
  shopDomain String
  orderId    String
  action     String
  actorType  String
  oldValue   String?
  newValue   String?
  notes      String?
  createdAt  DateTime   @default(now())

  @@index([shopDomain, orderId])
  @@index([shopDomain, createdAt(sort: Desc)])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  shopDomain  String
  topic       String
  eventId     String   // X-Shopify-Webhook-Id header
  processedAt DateTime @default(now())
  status      String @default("OK")
  error       String?

  @@unique([shopDomain, topic, eventId])   // idempotency key
  @@index([shopDomain, topic])
}


